generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  LECTURER
  ADMIN
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  role         UserRole     @default(LECTURER)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  submissions  Submission[]
  markedResults Result[]    @relation("ResultMarker")
}

model Submission {
  id               String    @id @default(uuid())
  originalFileName String
  storedFileName   String
  filePath         String
  fileType         String
  fileSize         Int
  extractedText    String
  cleanedText      String
  uploadedById     String
  uploadedBy       User      @relation(fields: [uploadedById], references: [id])
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  result           Result?   @relation("SubmissionResult")
  matchedInResults Result[]  @relation("MatchedSubmission")
  externalScan     ExternalScan?
}

model Result {
  id                  String      @id @default(uuid())
  submissionId        String      @unique
  submission          Submission  @relation("SubmissionResult", fields: [submissionId], references: [id])
  matchedSubmissionId String?
  matchedSubmission   Submission? @relation("MatchedSubmission", fields: [matchedSubmissionId], references: [id])
  similarityScore     Int
  colorIndicator      String
  riskLevel           String
  matchedPassages     Json?
  reviewStatus        ReviewStatus @default(PENDING_REVIEW)
  markScore           Float?
  markerComment       String?
  markedById          String?
  markedBy            User?        @relation("ResultMarker", fields: [markedById], references: [id])
  markedAt            DateTime?
  createdAt           DateTime    @default(now())
}

enum ReviewStatus {
  PENDING_REVIEW
  IN_REVIEW
  MARKED
}

enum ExternalScanStatus {
  QUEUED
  SUBMITTED
  COMPLETED
  FAILED
}

model ExternalScan {
  id             String             @id @default(uuid())
  submissionId   String             @unique
  submission     Submission         @relation(fields: [submissionId], references: [id])
  provider       String
  providerScanId String             @unique
  status         ExternalScanStatus @default(QUEUED)
  rawPayload     Json?
  errorMessage   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  completedAt    DateTime?
  sourceMatches  ExternalSourceMatch[]
}

model ExternalSourceMatch {
  id             String       @id @default(uuid())
  externalScanId String
  externalScan   ExternalScan @relation(fields: [externalScanId], references: [id], onDelete: Cascade)
  sourceType     String?
  title          String?
  url            String?
  matchedWords   Int?
  similarity     Int?
  snippet        String?
  sourceSnippet  String?
  metadata       Json?
  createdAt      DateTime     @default(now())
}
